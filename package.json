{
  "name": "multi-turtle-cli-dev",
  "private": true,
  "version": "0.1.0",
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "node scripts/dev-client.mjs",
    "dev:client:raw": "vite",
    "dev:server": "npm.cmd --prefix server run dev",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.4"
  }
}
